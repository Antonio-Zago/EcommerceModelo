@using Application.Dtos.HomePage
@model HomeDto

@{
    ViewData["Title"] = "Home Page";
    var homeDto = Model ?? new();
}

<link rel="stylesheet" href="~/css/carrousel.css" asp-append-version="true" />

<!-- Carrossel full-bleed (quebra o padding do container) -->
<div class="mx-n4 mx-md-n5">
    <div id="carouselHome" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4500">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="0" class="active" aria-current="true"></button>
            <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="2"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/images/banner1.png" alt="Banner 1" class="d-block w-100">
            </div>
            <div class="carousel-item">
                <img src="~/images/banner2.png" alt="Banner 2" class="d-block w-100">
            </div>
            <div class="carousel-item">
                <img src="~/images/banner3.png" alt="Banner 3" class="d-block w-100">
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselHome" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Anterior</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselHome" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Próximo</span>
        </button>
    </div>
</div>

<!-- Categorias -->
<div class="mt-5 pt-2">
    <div class="section-header">
        <h2 class="section-title">Categorias</h2>
        <a href="/Produtos" class="section-link">Ver todas →</a>
    </div>
    <div class="scroll-section">
        <button class="scroll-btn scroll-btn-left" onclick="scrollCategorias(-300, 'categoriasContainer')">❮</button>
        <div id="categoriasContainer" class="items-scroll">
            @foreach (var categoria in homeDto.Categorias)
            {
                <div style="min-width: 300px; width: 300px; flex-shrink: 0;">
                    @await Html.PartialAsync("_CardCategoria", categoria)
                </div>
            }
        </div>
        <button class="scroll-btn scroll-btn-right" onclick="scrollCategorias(300, 'categoriasContainer')">❯</button>
    </div>
</div>

