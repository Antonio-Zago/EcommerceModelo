@using Application.Dtos.HomePage
@model HomeDto

@{
    ViewData["Title"] = "Home Page";
    var homeDto = Model ?? new();
}

<!-- Carrossel de Imagens -->
<div id="carouselHome" class="carousel carousel-dark slide my-4" data-bs-ride="carousel">
    <ol class="carousel-indicators">
        <li data-bs-target="#carouselHome" data-bs-slide-to="0" class="active"></li>
        <li data-bs-target="#carouselHome" data-bs-slide-to="1"></li>
        <li data-bs-target="#carouselHome" data-bs-slide-to="2"></li>
    </ol>
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/images/banner1.png" alt="Banner 1" class="d-block w-100">
        </div>
        <div class="carousel-item">
            <img src="~/images/banner2.png" alt="Banner 2" class="d-block w-100">
        </div>
        <div class="carousel-item">
            <img src="~/images/banner3.png" alt="Banner 3" class="d-block w-100">
        </div>
    </div>
    <a class="carousel-control-prev" href="#carouselHome" role="button" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Anterior</span>
    </a>
    <a class="carousel-control-next" href="#carouselHome" role="button" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Próximo</span>
    </a>
</div>

<div class="mt-5">

    <div class="d-flex align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">
            Categorias
        </h2>

        <div class="flex-grow-1 ms-3 border-bottom"></div>
    </div>

    <div class="position-relative">

        <!-- Botão Esquerda -->
        <button class="btn btn-light shadow categoria-btn-left"
                onclick="scrollCategorias(-300)">
            ❮
        </button>

        <!-- Categorias -->
        <div id="categoriasContainer"
             class="d-flex overflow-auto gap-3 pb-3 categorias-scroll">

            @foreach (var categoria in homeDto.Categorias)
            {
                <div style="min-width: 350px;">
                    @await Html.PartialAsync("_CardCategoria", categoria)
                </div>
            }

        </div>

        <!-- Botão Direita -->
        <button class="btn btn-light shadow categoria-btn-right"
                onclick="scrollCategorias(300)">
            ❯
        </button>

    </div>

</div>

