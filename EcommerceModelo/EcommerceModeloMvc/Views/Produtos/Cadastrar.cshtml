@model EcommerceModeloMvc.ViewModels.CadastroProdutoViewModel
@using Domain.Models

@{
    ViewData["Title"] = "Cadastrar Produto";
    var categorias = ViewBag.Categorias as IEnumerable<Categoria> ?? Enumerable.Empty<Categoria>();
    var opcoesTamanho = ViewBag.OpcoesTamanho as IEnumerable<OpcaoTamanho> ?? Enumerable.Empty<OpcaoTamanho>();
    var tamanhosPorTipo = opcoesTamanho.GroupBy(o => o.Tipo?.Nome ?? "Geral").ToList();

    var breadcrumb = new List<BreadcrumbItem>
    {
        new("Início", "/"),
        new("Cadastrar produto")
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/cadastroProduto.css" asp-append-version="true" />
}

@await Html.PartialAsync("_Breadcrumb", breadcrumb)

<div class="row justify-content-center">

<h1 class="mb-4">Cadastrar produto</h1>
<div class="col-12 col-xl-9 col-xxl-8">

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @ViewData.ModelState[string.Empty]!.Errors.FirstOrDefault()?.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form id="formCadastroProduto" asp-action="Cadastrar" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    @* ── Dados do Produto ── *@
    <div class="form-section-card">
        <div class="form-section-title">Dados do Produto</div>
        <div class="row g-3">

            <div class="col-12 col-md-8">
                <label asp-for="Nome" class="form-label">Nome <span class="text-danger">*</span></label>
                <input asp-for="Nome" class="form-control" placeholder="Ex.: Camiseta Básica Algodão" maxlength="200" />
                <span asp-validation-for="Nome" class="text-danger small"></span>
            </div>

            <div class="col-6 col-md-2">
                <label asp-for="Preco" class="form-label">Preço (R$) <span class="text-danger">*</span></label>
                <input asp-for="Preco" class="form-control" type="number" step="0.01" min="0.01" placeholder="0,00" />
                <span asp-validation-for="Preco" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Descricao" class="form-label">Descrição <span class="text-danger">*</span></label>
                <textarea asp-for="Descricao" class="form-control" rows="3" placeholder="Descreva o produto..."></textarea>
                <span asp-validation-for="Descricao" class="text-danger small"></span>
            </div>

            @* ── Categoria (FK única) ── *@
            @if (categorias.Any())
            {
                <div class="col-12 col-md-5">
                    <label asp-for="CategoriaId" class="form-label">Categoria <span class="text-danger">*</span></label>
                    <select asp-for="CategoriaId" class="form-select">
                        <option value="">— Selecione —</option>
                        @foreach (var cat in categorias)
                        {
                            <option value="@cat.Id" selected="@(Model.CategoriaId == cat.Id)">@cat.Nome</option>
                        }
                    </select>
                    <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                </div>
            }

            @* ── Tamanhos e Estoque ── *@
            <div class="col-12">
                <label class="form-label">Tamanhos e Estoque <span class="text-danger">*</span></label>
                
                <div id="tamanhoEstoqueRows">
                    <select class="form-select form-select-sm sel-tipo mb-1" style="max-width:150px;">
                            <option value="">Tipo</option>
                            @foreach (var grupo in tamanhosPorTipo)
                            {
                                <option value="@grupo.Key">@grupo.Key</option>
                            }
                    </select>
                    <div class="tamanho-row d-flex align-items-center gap-2 mb-2">
                        
                        <select name="Tamanhos[0].TamanhoId" class="form-select form-select-sm sel-opcao" style="max-width:150px;" required disabled>
                            <option value="">Opção</option>
                        </select>
                        <input name="Tamanhos[0].QtdEstoque" type="number" min="0" placeholder="Qtd."
                               class="form-control form-control-sm" style="max-width:100px;" required />
                        <button type="button" class="btn btn-outline-danger btn-sm btn-remover-tamanho" title="Remover" disabled>
                            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/>
                            </svg>
                        </button>
                    </div>
                </div>
                <button type="button" id="btnAdicionarTamanho" class="btn btn-outline-secondary btn-sm mt-1">
                    + Adicionar tamanho
                </button>
                <span id="erroTamanhos" class="text-danger small d-block mt-1" style="display:none !important;"></span>
                @if (ViewData.ModelState["Tamanhos"]?.Errors.Count > 0)
                {
                    <div class="text-danger small mt-1">
                        @foreach (var err in ViewData.ModelState["Tamanhos"]!.Errors)
                        { <div>@err.ErrorMessage</div> }
                    </div>
                }
            </div>

        </div>
    </div>

    @* ── Imagens do Produto ── *@
    <div class="form-section-card">
        <div class="form-section-title">Imagens do Produto</div>

        <input type="file" id="inputImagens" name="Imagens" multiple accept="image/*" style="display:none" />
        <input type="hidden" id="imagemPrincipalIndex" name="ImagemPrincipalIndex" value="0" />

        <div class="upload-area mb-3" id="uploadArea">
            <button type="button" id="btnAdicionarImagem" class="btn btn-outline-secondary">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="me-1">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="17 8 12 3 7 8"/>
                    <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
                Adicionar Imagem
            </button>
            <p class="text-muted small mt-2 mb-0">JPG, PNG ou WebP · máx. 5 MB por arquivo</p>
        </div>

        <span id="erroImagens" class="text-danger small" style="display:none;"></span>
        @if (ViewData.ModelState["Imagens"]?.Errors.Count > 0)
        {
            <div class="text-danger small">
                @foreach (var err in ViewData.ModelState["Imagens"]!.Errors)
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <div id="previewGrid" class="preview-grid"></div>
    </div>

    @* ── Ações ── *@
    <div class="d-flex justify-content-between mt-2 mb-5">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
        <button type="submit" class="btn btn-primary px-5">Cadastrar Produto</button>
    </div>
</form>

</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Serializa as opções de tamanho para uso dinâmico no JS (adicionar linha)
        window.OPCOES_TAMANHO = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            tamanhosPorTipo.Select(g => new {
                tipo = g.Key,
                opcoes = g.Select(o => new { id = o.Id, descricao = o.Descricao })
            })
        ));
    </script>
    <script src="~/js/cadastroProduto.js" asp-append-version="true"></script>
}
