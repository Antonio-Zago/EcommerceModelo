@using Application.Dtos.HomePage
@using EcommerceModeloMvc.ViewModels
@model IEnumerable<ProdutoDto>

@{
    ViewData["Title"] = "Feminino";

    var breadcrumb = new List<BreadcrumbItem>
    {
        new("Início", "/"),
        new("Feminino")
    };

    var filters = new List<FilterGroupViewModel>
    {
        new()
        {
            Label = "Gênero",
            Type  = FilterType.Checkbox,
            Options =
            [
                new() { Id = "masculino", Label = "Masculino" },
                new() { Id = "feminino",  Label = "Feminino"  },
            ]
        },
        new()
        {
            Label = "Categoria",
            Type  = FilterType.Checkbox,
            Options =
            [
                new() { Id = "camisas",   Label = "Camisas"   },
                new() { Id = "calcas",    Label = "Calças"    },
                new() { Id = "bermudas",  Label = "Bermudas"  },
                new() { Id = "camisetas", Label = "Camisetas" },
                new() { Id = "polos",     Label = "Polos"     },
                new() { Id = "shorts",    Label = "Shorts"    },
            ]
        },
        new()
        {
            Label = "Cor",
            Type  = FilterType.Checkbox,
            Options =
            [
                new() { Id = "preto",  Label = "Preto"  },
                new() { Id = "branco", Label = "Branco" },
            ]
        },
        new()
        {
            Label = "Marca",
            Type  = FilterType.Checkbox,
            Options =
            [
                new() { Id = "nike",   Label = "Nike"   },
                new() { Id = "adidas", Label = "Adidas" },
            ]
        },
        new()
        {
            Label = "Preço",
            Type  = FilterType.Range,
            Range = new() { Min = 0, Max = 1000, Step = 10, Value = 500 }
        },
    };

    var resultsBar = new ResultsBarViewModel { Shown = 30, Total = 1000 };
}

<link rel="stylesheet" href="~/css/listarRoupas.css" asp-append-version="true" />

@await Html.PartialAsync("_Breadcrumb", breadcrumb)

<h1 class="mb-4">Feminino</h1>

@await Html.PartialAsync("_FilterBar", filters)

<!-- Filtros aplicados -->
<div class="active-filters mb-4" id="active-filters">
    <span class="filter-tag">
        Feminino
        <button type="button" class="filter-tag-remove" aria-label="Remover filtro">×</button>
    </span>
</div>

@await Html.PartialAsync("_ResultsBar", resultsBar)

<div class="page-divider mb-4"></div>

<!-- Grade de produtos -->
<div class="row g-3">
    @if (Model != null && Model.Any())
    {
        foreach (var produto in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                @await Html.PartialAsync("_Card", produto)
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <p class="empty-state-text">Nenhuma roupa feminina encontrada.</p>
        </div>
    }
</div>

@await Html.PartialAsync("_VerMais", (string?)null)

@section Scripts {
    <script src="~/js/filtrosRoupasFemininas.js" asp-append-version="true"></script>
}
