@using Application.Dtos.HomePage
@using EcommerceModeloMvc.ViewModels
@model IEnumerable<ProdutoDto>

@{
    ViewData["Title"] = "Infantil";

    var breadcrumb = new List<BreadcrumbItem>
    {
        new("Início", "/"),
        new("Infantil")
    };

    var filters = new List<FilterGroupViewModel>
    {
        new()
        {
            Label = "Gênero",
            Type  = FilterType.Checkbox,
            Options =
            [
                new() { Id = "menino",    Label = "Menino"    },
                new() { Id = "menina",    Label = "Menina"    },
                new() { Id = "unissex",   Label = "Unissex"   },
            ]
        },
        new()
        {
            Label = "Categoria",
            Type  = FilterType.Checkbox,
            Options =
            [
                new() { Id = "camisetas",  Label = "Camisetas"  },
                new() { Id = "calcas",     Label = "Calças"     },
                new() { Id = "vestidos",   Label = "Vestidos"   },
                new() { Id = "conjuntos",  Label = "Conjuntos"  },
                new() { Id = "moletons",   Label = "Moletons"   },
                new() { Id = "shorts",     Label = "Shorts"     },
            ]
        },
        new()
        {
            Label   = "Idade",
            Type    = FilterType.SizeGrid,
            Options =
            [
                new() { Id = "0-2",   Label = "0–2"   },
                new() { Id = "2-4",   Label = "2–4"   },
                new() { Id = "4-6",   Label = "4–6"   },
                new() { Id = "6-8",   Label = "6–8"   },
                new() { Id = "8-10",  Label = "8–10"  },
                new() { Id = "10-12", Label = "10–12" },
            ]
        },
        new()
        {
            Label = "Cor",
            Type  = FilterType.Checkbox,
            Options =
            [
                new() { Id = "azul",      Label = "Azul"      },
                new() { Id = "rosa",      Label = "Rosa"      },
                new() { Id = "amarelo",   Label = "Amarelo"   },
                new() { Id = "verde",     Label = "Verde"     },
                new() { Id = "vermelho",  Label = "Vermelho"  },
            ]
        },
        new()
        {
            Label = "Preço",
            Type  = FilterType.Range,
            Range = new() { Min = 0, Max = 500, Step = 10, Value = 250 }
        },
    };

    var resultsBar = new ResultsBarViewModel { Shown = 30, Total = 1000 };
}

<link rel="stylesheet" href="~/css/listarRoupas.css" asp-append-version="true" />

@await Html.PartialAsync("_Breadcrumb", breadcrumb)

<h1 class="page-title mb-4">Infantil</h1>

@await Html.PartialAsync("_FilterBar", filters)

<!-- Filtros aplicados -->
<div class="active-filters mb-4" id="active-filters">
    <span class="filter-tag">
        Infantil
        <button type="button" class="filter-tag-remove" aria-label="Remover filtro">×</button>
    </span>
</div>

@await Html.PartialAsync("_ResultsBar", resultsBar)

<div class="page-divider mb-4"></div>

<!-- Grade de produtos -->
<div class="row g-3">
    @if (Model != null && Model.Any())
    {
        foreach (var produto in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                @await Html.PartialAsync("_Card", produto)
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <p class="empty-state-text">Nenhuma roupa infantil encontrada.</p>
        </div>
    }
</div>

@await Html.PartialAsync("_VerMais", (string?)null)

@section Scripts {
    <script src="~/js/filtrosRoupasInfantis.js" asp-append-version="true"></script>
}
