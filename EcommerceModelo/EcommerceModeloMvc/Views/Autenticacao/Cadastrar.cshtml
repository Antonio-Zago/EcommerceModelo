@model EcommerceModeloMvc.ViewModels.CadastroUsuarioViewModel

@{
    ViewData["Title"] = "Criar conta";

    var breadcrumb = new List<BreadcrumbItem>
    {
        new("Início", "/"),
        new("Criar conta")
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/autenticacao.css" asp-append-version="true" />
}

@await Html.PartialAsync("_Breadcrumb", breadcrumb)

<div class="auth-wrapper">
    <div class="auth-card">

        <h1 class="auth-title">Criar conta</h1>
        <p class="auth-subtitle">Preencha os dados abaixo para se cadastrar</p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                @ViewData.ModelState[string.Empty]!.Errors.FirstOrDefault()?.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form asp-action="Cadastrar" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Nome" class="auth-label">Nome completo</label>
                <input asp-for="Nome"
                       class="auth-input @(ViewData.ModelState["Nome"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       type="text"
                       placeholder="João Silva"
                       autocomplete="name" />
                <span asp-validation-for="Nome" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="auth-label">E-mail</label>
                <input asp-for="Email"
                       class="auth-input @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       type="email"
                       placeholder="seu@email.com"
                       autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Senha" class="auth-label">Senha <span class="text-muted" style="font-weight:400">(mínimo 8 caracteres)</span></label>
                <input asp-for="Senha"
                       class="auth-input @(ViewData.ModelState["Senha"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       type="password"
                       placeholder="••••••••"
                       autocomplete="new-password" />
                <span asp-validation-for="Senha" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmarSenha" class="auth-label">Confirmar senha</label>
                <input asp-for="ConfirmarSenha"
                       class="auth-input @(ViewData.ModelState["ConfirmarSenha"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       type="password"
                       placeholder="••••••••"
                       autocomplete="new-password" />
                <span asp-validation-for="ConfirmarSenha" class="text-danger small"></span>
            </div>

            <button type="submit" class="auth-btn">Criar conta</button>
        </form>

        <div class="auth-divider">ou</div>

        <p class="auth-footer-text">
            Já tem uma conta?
            <a asp-action="Login" class="auth-link">Entrar</a>
        </p>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
