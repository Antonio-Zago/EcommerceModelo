@model EcommerceModeloMvc.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Entrar";
    var returnUrl = ViewBag.ReturnUrl as string;

    var breadcrumb = new List<BreadcrumbItem>
    {
        new("Início", "/"),
        new("Entrar")
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/autenticacao.css" asp-append-version="true" />
}

@await Html.PartialAsync("_Breadcrumb", breadcrumb)

<div class="auth-wrapper">
    <div class="auth-card">

        <h1 class="auth-title">Bem-vindo</h1>
        <p class="auth-subtitle">Faça login para continuar</p>

        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                @TempData["Sucesso"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                @ViewData.ModelState[string.Empty]!.Errors.FirstOrDefault()?.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            @if (!string.IsNullOrWhiteSpace(returnUrl))
            {
                <input type="hidden" name="returnUrl" value="@returnUrl" />
            }

            <div class="mb-3">
                <label asp-for="Email" class="auth-label">E-mail</label>
                <input asp-for="Email"
                       class="auth-input @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       type="email"
                       placeholder="seu@email.com"
                       autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label asp-for="Senha" class="auth-label mb-0">Senha</label>
                </div>
                <input asp-for="Senha"
                       class="auth-input @(ViewData.ModelState["Senha"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       type="password"
                       placeholder="••••••••"
                       autocomplete="current-password" />
                <span asp-validation-for="Senha" class="text-danger small"></span>
            </div>

            <div class="d-flex align-items-center gap-2 mb-3">
                <input asp-for="Lembrar" class="form-check-input mt-0" type="checkbox" id="lembrar" />
                <label class="remember-label" for="lembrar">Manter conectado por 30 dias</label>
            </div>

            <button type="submit" class="auth-btn">Entrar</button>
        </form>

        <div class="auth-divider">ou</div>

        <p class="auth-footer-text">
            Ainda não tem conta?
            <a asp-action="Cadastrar" class="auth-link">Criar conta</a>
        </p>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
