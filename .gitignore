## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
publish/

# Visual Studio cache
.vs/

# Rider
.idea/

# VS Code
.vscode/

# ASP.NET Core
appsettings.Development.json

# User Secrets
secrets.json

# Logs
*.log
logs/

# NuGet
*.nupkg
.nuget/packages/

# Entity Framework
*.dbmdl

# IIS Express
iisexpress/

# SQL Server
*.mdf
*.ldf

# SQLite
*.sqlite
*.db


# Node modules (caso use frontend)
node_modules/

# Frontend build
dist/
wwwroot/dist/

# OS files
.DS_Store
Thumbs.db

# Test results
TestResults/

# Coverage
coverage/
*.coverage
*.coveragexml

# Publish output
publish/

# Temporary files
*.tmp
*.temp

# Resharper
_ReSharper*/
*.DotSettings.user

# Azure
PublishProfiles/

# Certificates
*.pfx
*.pem
*.key

# JetBrains Rider
*.sln.iml

# npm
npm-debug.log*

# yarn
yarn-debug.log*
yarn-error.log*

# dotenv
.env
.env.*

# Docker volumes
postgres_data/
redis_data/

# Generated files
Generated/